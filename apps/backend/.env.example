# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:YOUR_PG_PASSWORD@localhost:5432/mystore

# ── CORS (adjust origins for your brand's domain) ────────────────────────────
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000,http://localhost:8000

# ── Secrets (generate with: openssl rand -hex 32) ───────────────────────────
JWT_SECRET=supersecret_change_me
COOKIE_SECRET=supersecret_change_me

# ── First admin (auto-created on first `db:migrate`) ─────────────────────────
# Set these BEFORE the first deploy and the super-admin is created + granted the
# Owner role automatically — no manual `medusa user` step needed. Leave unset to
# create the admin by hand instead. Runs once; changing the password here later
# does NOT rotate it (use `npx medusa user` or the admin UI for that).
# ADMIN_EMAIL=owner@yourstore.com
# ADMIN_PASSWORD=change_me_to_a_strong_password
# ADMIN_FIRST_NAME=Owner

# ── Backend URL (used to build payment callback URLs) ────────────────────────
# BACKEND_URL=http://localhost:9000

# All integration secrets below are read from the environment. They are NOT stored
# in the admin dashboard. Set the ones you use, then restart the backend. Each
# provider's on/off toggle and non-secret settings live in Admin → Store Settings.

# ── Stripe (optional — international cards, Apple Pay, Google Pay) ────────────
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook endpoint to register in Stripe dashboard: {BACKEND_URL}/hooks/payment/stripe_stripe

# ── SSLCommerz (optional — BD aggregator: cards, bKash, Nagad, Rocket, EMI) ──
# SSLCOMMERZ_STORE_ID=your_store_id
# SSLCOMMERZ_STORE_PASSWORD=your_store_password
# SSLCOMMERZ_SANDBOX=true          # set to false for live

# ── bKash direct (optional — tokenized PGW; most merchants use SSLCommerz) ───
# BKASH_APP_KEY=your_app_key
# BKASH_APP_SECRET=your_app_secret
# BKASH_USERNAME=your_username
# BKASH_PASSWORD=your_password
# BKASH_SANDBOX=true               # set to false for live

# ── Email — Resend (optional) ────────────────────────────────────────────────
# RESEND_API_KEY=re_...            # API key with Sending access — enables email
# RESEND_FROM_EMAIL=noreply@yourdomain.com   # from-address on a Resend-verified domain
# RESEND_FROM_NAME=My Store        # optional; also editable in Store Settings
# STORE_URL=https://yourdomain.com # used inside email templates (logo, links)

# ── SMS (optional — Twilio or a generic HTTP gateway) ────────────────────────
# SMS_API_KEY=ACxxxxxxxx           # Twilio Account SID, or your gateway API key
# TWILIO_AUTH_TOKEN=your_auth_token # Twilio only
# SMS_PROVIDER=twilio              # "twilio" or "generic_http" (also editable in Store Settings)
# SMS_SENDER_ID=+18005551234       # from-number / sender ID
# SMS_API_URL=https://gateway/api/send   # generic_http gateways only

# ── Meta Conversions API (optional — server-side Purchase events) ────────────
# META_CAPI_ACCESS_TOKEN=EAAB...   # from Events Manager → your Pixel → Conversions API
# (Pixel ID / GA4 ID / test-event code are set in Admin → Store Settings, not here)

# ── Google Sign-In (optional) ────────────────────────────────────────────────
# GOOGLE_CLIENT_SECRET=GOCSPX-...  # the secret only; client ID + redirect URI are in Store Settings

# ── Couriers (optional — Bangladesh; only one active at a time) ──────────────
# Steadfast (no sandbox):
# STEADFAST_API_KEY=your_api_key
# STEADFAST_SECRET_KEY=your_secret_key
# RedX:
# REDX_API_TOKEN=your_api_token
# REDX_SANDBOX=false               # "true" for the sandbox gateway
# Pathao:
# PATHAO_CLIENT_ID=your_client_id
# PATHAO_CLIENT_SECRET=your_client_secret
# PATHAO_USERNAME=merchant@example.com
# PATHAO_PASSWORD=your_password
# PATHAO_STORE_ID=12345            # optional
# PATHAO_SANDBOX=false             # "true" for the sandbox gateway

# ── File storage (MinIO / S3) ─────────────────────────────────────────────────
# Local dev: run `docker compose up -d` (repo root) to start MinIO, then use these:
S3_ENDPOINT=http://localhost:9100
S3_BUCKET=medusa-store
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_FILE_URL=http://localhost:9100/medusa-store
#
# Production (Coolify): replace the values above with your Coolify MinIO resource values.
# See docs/02-deployment.md Section 4d for setup instructions.

# ── Misc ──────────────────────────────────────────────────────────────────────
MEDUSA_ADMIN_ONBOARDING_TYPE=nextjs
# REDIS_URL=redis://localhost:6379  # optional; in-memory fallback used otherwise
