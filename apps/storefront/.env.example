# ── Medusa backend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Get this key from Admin → Settings → API Keys after first run
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...

# ── Region / locale ───────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_REGION=us
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# ── Stripe (optional — only if backend has Stripe enabled) ───────────────────
# NEXT_PUBLIC_STRIPE_KEY=pk_test_...

# ── Analytics pixels (all optional — omit or leave blank to disable) ─────────
# Google Tag Manager (fires PageView automatically; use GTM to manage all other tags)
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Meta (Facebook) Pixel
# NEXT_PUBLIC_META_PIXEL_ID=1234567890

# TikTok Pixel
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=ABCDEFGHIJ

# Google Ads conversion ID (e.g. AW-123456789)
# NEXT_PUBLIC_GADS_ID=AW-123456789
